{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/runtime-config",
      "dest": "/api/runtime-config.js"
    },
    {
      "src": "/api/health",
      "dest": "/api/health.js"
    },
    {
      "src": "/api/room-create",
      "dest": "/api/room-create.js"
    },
    {
      "src": "/api/room-join",
      "dest": "/api/room-join.js"
    },
    {
      "src": "/api/room-leave",
      "dest": "/api/room-leave.js"
    },
    {
      "src": "/api/signal-send",
      "dest": "/api/signal-send.js"
    },
    {
      "src": "/api/signal-poll",
      "dest": "/api/signal-poll.js"
    },
    {
      "src": "/(.*)",
      "methods": ["GET", "HEAD"],
      "dest": "/client/index.html"
    }
  ]
}
